# Zerion API key (get from dashboard.zerion.io)
ZERION_API_KEY=zk_...

# Telegram bot token (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# Birdeye API key for SOL/USDC OHLCV data (get from birdeye.so)
BIRDEYE_API_KEY=

# ML service URL (default: http://localhost:8002)
ML_SERVICE_URL=http://localhost:8002

# Agent token (auto-set after running setup-token.sh, or set manually)
# ZERION_AGENT_TOKEN=
